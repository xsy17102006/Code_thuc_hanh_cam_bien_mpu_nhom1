#include <Wire.h>

const int MPU = 0x68;

// ===== Raw data =====
float AccX, AccY, AccZ;
float GyroY;
float gyro_offset = 0;

// ===== Kalman parameters =====
float Q_angle = 0.005;
float Q_bias  = 0.006;
float R_measure = 0.05;

float angle = 0;
float bias = 0;
float P[2][2] = { {0,0}, {0,0} };

unsigned long lastTime;

// ===== Kalman =====
float Kalman(float newAngle, float newRate, float dt) {

  // Predict
  float rate = newRate - bias;
  angle += dt * rate;

  P[0][0] += dt * (dt * P[1][1] - P[0][1] - P[1][0] + Q_angle);
  P[0][1] -= dt * P[1][1];
  P[1][0] -= dt * P[1][1];
  P[1][1] += Q_bias * dt;

  // Update
  float S = P[0][0] + R_measure;
  float K0 = P[0][0] / S;
  float K1 = P[1][0] / S;

  float y = newAngle - angle;

  angle += K0 * y;
  bias  += K1 * y;

  float P00 = P[0][0];
  float P01 = P[0][1];

  P[0][0] -= K0 * P00;
  P[0][1] -= K0 * P01;
  P[1][0] -= K1 * P00;
  P[1][1] -= K1 * P01;

  return angle;
}

// ===== Read MPU =====
void readMPU() {
  Wire.beginTransmission(MPU);
  Wire.write(0x3B);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU, 6, true);

  AccX = (Wire.read() << 8 | Wire.read()) / 16384.0;
  AccY = (Wire.read() << 8 | Wire.read()) / 16384.0;
  AccZ = (Wire.read() << 8 | Wire.read()) / 16384.0;

  Wire.beginTransmission(MPU);
  Wire.write(0x43);
  Wire.endTransmission(false);
  Wire.requestFrom(MPU, 2, true);

  GyroY = (Wire.read() << 8 | Wire.read()) / 131.0;
}

// ===== Setup =====
void setup() {
  Serial.begin(115200);
  Wire.begin();

  Wire.beginTransmission(MPU);
  Wire.write(0x6B);
  Wire.write(0);
  Wire.endTransmission(true);

  lastTime = micros();

  // ===== gyro calibration =====
  Serial.println("Calibrating gyro...");

  float sum = 0;
  for (int i = 0; i < 500; i++) {
    readMPU();
    sum += GyroY;
    delay(5);
  }

  gyro_offset = sum / 500.0;

  Serial.print("Gyro offset: ");
  Serial.println(gyro_offset);
}

// ===== Loop =====
void loop() {

  readMPU();

  GyroY -= gyro_offset;

  // ===== ACCEL FILTER (QUAN TRỌNG) =====
  static float acc_filtered = 0;
  float acc_raw = atan2(AccX, AccZ) * 57.3;

  acc_filtered = 0.9 * acc_filtered + 0.1 * acc_raw;

  // ===== dt =====
  unsigned long now = micros();
  float dt = (now - lastTime) / 1000000.0;
  lastTime = now;

  // ===== Kalman =====
  float kalmanAngle = Kalman(acc_filtered, GyroY, dt);

  // ===== Output =====
  Serial.print("Acc: ");
  Serial.print(acc_raw);
  Serial.print(" | Kalman: ");
  Serial.println(kalmanAngle);

  delay(5);
}
